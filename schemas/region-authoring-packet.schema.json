{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/brenowilson/voynich/schemas/region-authoring-packet.schema.json",
  "title": "Source-Pixel Region Authoring Packet",
  "type": "object",
  "required": [
    "schema_version",
    "packet_id",
    "trial_id",
    "candidate_id",
    "photographic_panel_id",
    "blank_package",
    "source",
    "annotator_id",
    "annotated_at",
    "regions",
    "external_transliterations_used",
    "semantic_interpretation_used",
    "reading_order_asserted",
    "technical_review_completed",
    "scientific_adjudication_used",
    "production_freeze_authorized"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "packet_id": {"type": "string", "pattern": "^REGION-PACKET-PILOT-0001-CAND-[0-9]{3}$"},
    "trial_id": {"const": "REGION-ANNOTATION-TRIAL-0001"},
    "candidate_id": {"type": "string", "pattern": "^PILOT-0001-CAND-[0-9]{3}$"},
    "photographic_panel_id": {"type": "string", "pattern": "^YDC-PANEL-[0-9]+$"},
    "blank_package": {
      "type": "object",
      "required": ["package_id", "package_path", "package_sha256"],
      "properties": {
        "package_id": {"type": "string", "pattern": "^OBS-PKG-YDC-PANEL-[0-9]+-R000$"},
        "package_path": {"type": "string", "minLength": 1},
        "package_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": [
        "source_url",
        "source_sha256",
        "width_px",
        "height_px",
        "coordinate_origin",
        "coordinate_units"
      ],
      "properties": {
        "source_url": {"type": "string", "format": "uri"},
        "source_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "width_px": {"type": "integer", "minimum": 1},
        "height_px": {"type": "integer", "minimum": 1},
        "coordinate_origin": {"const": "top_left"},
        "coordinate_units": {"const": "source_pixels"}
      },
      "additionalProperties": false
    },
    "annotator_id": {
      "type": ["string", "null"],
      "pattern": "^OBS-[A-Z0-9-]+$"
    },
    "annotated_at": {"type": ["string", "null"], "format": "date-time"},
    "regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "region_id",
          "role",
          "polygon",
          "confidence",
          "visibility",
          "observation_status",
          "evidence_note"
        ],
        "properties": {
          "region_id": {"type": "string", "pattern": "^OBSREG-YDC-PANEL-[0-9]+-[0-9]{4}$"},
          "role": {
            "enum": [
              "text_bearing",
              "graphic_bearing",
              "mixed",
              "unmarked_or_background",
              "obscured_or_damaged",
              "uncertain"
            ]
          },
          "polygon": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "array",
              "prefixItems": [
                {"type": "integer", "minimum": 0},
                {"type": "integer", "minimum": 0}
              ],
              "minItems": 2,
              "maxItems": 2
            }
          },
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "visibility": {"enum": ["clear", "partial", "obscured", "damaged", "uncertain"]},
          "observation_status": {"const": "active"},
          "evidence_note": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "external_transliterations_used": {"const": false},
    "semantic_interpretation_used": {"const": false},
    "reading_order_asserted": {"const": false},
    "technical_review_completed": {"const": false},
    "scientific_adjudication_used": {"const": false},
    "production_freeze_authorized": {"const": false}
  },
  "additionalProperties": false
}
